# Firebase Configuration (required for cloud features)
# Copy this file to .env and fill in your Firebase project values.
# These are NOT needed for the open-source offline-only build.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Billing API URL (optional — for Stripe integration)
VITE_BILLING_API_URL=

# Cloud plugin toggle — set to "true" in official release builds only.
# When absent or "false", the app runs in community/offline mode.
VITE_CLOUD_ENABLED=false
